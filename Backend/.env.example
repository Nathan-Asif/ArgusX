# ArgusX Backend — environment template.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All variables are prefixed with ARGUSX_ (see config/argusx_settings.py).

# --- Application identity ---
ARGUSX_APP_NAME=ArgusX Orchestrator
ARGUSX_ENVIRONMENT=development
ARGUSX_DEBUG=true

# --- HTTP server ---
ARGUSX_HOST=0.0.0.0
# VPS shared host uses 8025 (8000/8002/8010/8080 often taken). Local dev: 8000
ARGUSX_PORT=8000
ARGUSX_CORS_ORIGINS=*

# --- Supabase / PostgreSQL data layer ---
ARGUSX_SUPABASE_URL=
ARGUSX_SUPABASE_KEY=
# Direct Postgres pooler URI from Supabase Dashboard > Settings > Database
ARGUSX_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
ARGUSX_DATABASE_ENABLED=true

# --- Local FAISS vector store ---
ARGUSX_VECTOR_INDEX_PATH=vector_store/faiss_index.bin
ARGUSX_VECTOR_DIMENSION=768

# --- Multimodal model (Gemini Live) ---
ARGUSX_GEMINI_API_KEY=
ARGUSX_GEMINI_MODEL=gemini-3.1-flash-live

# --- Google Maps Platform (Geocoding + Directions) ---
# Enable Geocoding API + Directions API + Maps Static API in Google Cloud Console.
ARGUSX_GOOGLE_MAPS_API_KEY=
ARGUSX_GOOGLE_MAPS_ENABLED=true
ARGUSX_GOOGLE_MAPS_TIMEOUT_SECONDS=10.0

# --- Auth (JWT) ---
ARGUSX_JWT_SECRET=change-me
ARGUSX_JWT_ALGORITHM=HS256
ARGUSX_JWT_EXPIRY_MINUTES=60

# --- Java compliance microservice ---
ARGUSX_COMPLIANCE_ENABLED=true
ARGUSX_COMPLIANCE_SERVICE_URL=http://127.0.0.1:8081
ARGUSX_COMPLIANCE_TIMEOUT_SECONDS=5.0
