# ArgusX Flutter HUD — environment template.
# Production URLs are baked into lib/config/argusx_config.dart by default.
#
# Local Chrome/desktop override:
#   flutter run -d chrome \
#     --dart-define=ARGUSX_WS_URL=ws://127.0.0.1:8000/ws/pulse \
#     --dart-define=ARGUSX_API_URL=http://127.0.0.1:8000
#
# Android emulator override:
#   --dart-define=ARGUSX_WS_URL=ws://10.0.2.2:8000/ws/pulse \
#   --dart-define=ARGUSX_API_URL=http://10.0.2.2:8000
#
# Production APK (defaults already point here — optional explicit build):
#   flutter build apk \
#     --dart-define=ARGUSX_WS_URL=wss://argusx-api.codemelodies.com/ws/pulse \
#     --dart-define=ARGUSX_API_URL=https://argusx-api.codemelodies.com

ARGUSX_WS_URL=wss://argusx-api.codemelodies.com/ws/pulse
ARGUSX_API_URL=https://argusx-api.codemelodies.com
ARGUSX_SUPABASE_URL=
ARGUSX_SUPABASE_ANON_KEY=
