# ArgusX Flutter HUD — environment template.
# Copy to `.env` for local reference. Flutter reads these via --dart-define at run time:
#
#   flutter run --dart-define=ARGUSX_WS_URL=ws://127.0.0.1:8000/ws/pulse --dart-define=ARGUSX_API_URL=http://127.0.0.1:8000

ARGUSX_WS_URL=ws://127.0.0.1:8000/ws/pulse
ARGUSX_API_URL=http://127.0.0.1:8000
