# ArgusX Web Portal — environment template.
# Copy to `.env.local` for local development against a laptop backend.

# Production (also CI/CD build defaults)
NEXT_PUBLIC_ARGUSX_API_URL=https://argusx-api.codemelodies.com
NEXT_PUBLIC_ARGUSX_WS_URL=wss://argusx-api.codemelodies.com/ws/pulse

# Local backend override (uncomment in .env.local)
# NEXT_PUBLIC_ARGUSX_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_ARGUSX_WS_URL=ws://127.0.0.1:8000/ws/pulse

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
